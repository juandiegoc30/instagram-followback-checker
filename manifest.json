{
  "manifest_version": 3,
  "name": "IG MutualCheck",
  "version": "1.1.0",
  "description": "Analiza tu cuenta de Instagram, filtra resultados y detecta cuentas que no te siguen de vuelta",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "action": {
    "default_title": "IG MutualCheck",
    "default_icon": "assets/icon.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/flags/4x3/us.svg",
        "assets/flags/4x3/es.svg"
      ],
      "matches": [
        "https://www.instagram.com/*"
      ]
    }
  ]
}